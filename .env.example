# Copy to `.env` and fill in. Every integration below is optional — a tool
# family is only registered when its config is present.

# --- Model (Ollama) ---
# Must match a tag from `ollama list`.
MINIPI_MODEL=LiquidAI/lfm2.5-1.2b-instruct
OLLAMA_BASE_URL=http://localhost:11434/v1
# Context window (tokens) for the model. Drives context-usage % and the /tidy hint.
# MINIPI_CONTEXT_WINDOW=128000
# Max tokens generated per response.
# MINIPI_MAX_TOKENS=8192

# --- Postgres tools (postgres_query, postgres_schema) ---
# Set to enable. Queries run with this connection's full privileges.
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb
# TLS mode. Managed cloud databases (Supabase, Neon, RDS, Heroku, ...) require this.
#   require  -> encrypt, don't verify cert (most cloud DBs)
#   verify   -> encrypt and verify (uses system CAs, or DATABASE_CA_CERT)
#   disable  -> no TLS (plain local Postgres; this is the default)
# DATABASE_SSL=require
# DATABASE_CA_CERT=/path/to/server-ca.pem

# --- Tavily web search (web_search) ---
# Get a key at https://tavily.com
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx
# TAVILY_BASE_URL=https://api.tavily.com

# --- MCP servers ---
# JSON array of stdio servers. Each server's tools are exposed as `<name>__<tool>`.
# MCP_SERVERS=[{"name":"fs","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"]}]

# --- System prompt ---
# The agent's system prompt is loaded from an editable markdown file at boot.
# Default: the bundled prompts/system.md. Point this at your own file to override
# (if the file is missing, the SDK's built-in default prompt is used).
# MINIPI_SYSTEM_PROMPT_PATH=/path/to/system.md

# --- Session resume (JSON-RPC) ---
# Persisted conversation threads live in ~/.pi/agent/sessions/. By default each
# `npm run rpc` launch starts a fresh thread. Set to 1 to continue the most recent
# thread for this directory instead (or start fresh if there is none).
# MINIPI_RESUME=1

# --- Context tidy ---
# Once context usage crosses this percentage, the TUI suggests /tidy (compact or
# clear). Default 75.
# MINIPI_CONTEXT_WARN_PCT=75

# --- Memory (memory_write, memory_read, memory_search) ---
# Long-term memory is ON by default. Facts are stored in MEMORY.md and injected
# into the system prompt at the start of each session. Set to off/0/false to disable.
# MINIPI_MEMORY=off
# Directory for the memory file. Default: <cwd>/.minipi/memory
# MINIPI_MEMORY_DIR=/path/to/memory
